# Database
DATABASE_URL=postgresql://agentbox:agentbox@localhost:5432/agentbox

# API
AGENTBOX_API_TOKEN=dev-token

# LLM API Keys (at least one required)
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# Model
MODEL_NAME=deepseek-chat

# Observability (optional — no-op if unset)
LOGFIRE_TOKEN=

# Runner
RUNNER_IMAGE=agentbox-runner:latest

# Launcher
AGENTBOX_BACKEND=docker
MAX_CONCURRENT_RUNS=3
