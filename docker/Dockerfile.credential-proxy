FROM python:3.12-slim

WORKDIR /app

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Install dependencies (FastAPI, httpx, uvicorn)
RUN pip install --no-cache-dir fastapi>=0.139.0 uvicorn[standard]>=0.51.0 httpx>=0.28.1 pydantic>=2.0.0

# Copy the proxy script
COPY credential_proxy.py ./credential_proxy.py

ENV PYTHONUNBUFFERED=1
EXPOSE 9090

ENTRYPOINT ["python", "credential_proxy.py"]
