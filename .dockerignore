# Version control
.git/
.gitignore
.gitattributes

# Environment
.env
.env.example

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# Tests
tests/
.coverage
coverage.xml

# Documentation (not needed in runtime image)
docs/
site/
*.md
!README.md
*.yml
*.yaml
!pyproject.toml

# The docker/ directory is the build context for Dockerfiles.
# Dockerfiles reference specific files from it (entrypoint.sh, credential_proxy.py).
# Excluding the whole directory breaks credential-proxy and control-plane builds.
# Keep it excluded from the runner context (build from project root) since the
# runner Dockerfile doesn't need docker/ files.
# docker/
Dockerfile*
.dockerignore

# K8s
k8s/

# IDE
.idea/
.vscode/
*.swp
*.swo
